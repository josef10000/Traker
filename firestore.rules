rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Funções auxiliares de segurança
    function getProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function getUserTeamId() {
      return getProfile().teamId;
    }

    function getUserOrganizationId() {
      return getProfile().organizationId;
    }
    
    function isSupervisor() {
      return getProfile().role == 'supervisor';
    }

    function isManager() {
      return getProfile().role == 'manager';
    }

    function isSuperAdmin() {
      return getProfile().role == 'super_admin';
    }
    
    // Coleção de organizações (organizations)
    match /organizations/{orgId} {
      allow create: if request.auth != null;
      allow read, update, delete: if request.auth != null && (isSuperAdmin() || (isManager() && getUserOrganizationId() == orgId));
    }

    // Coleção de usuários (users)
    match /users/{userId} {
      allow read: if request.auth != null && (isSuperAdmin() || getUserOrganizationId() == resource.data.organizationId);
      allow write: if request.auth != null && (isSuperAdmin() || request.auth.uid == userId || (isManager() && getUserOrganizationId() == request.resource.data.organizationId));
    }
    
    // Coleção de times (teams)
    match /teams/{teamId} {
      allow read: if request.auth != null && (isSuperAdmin() || getUserOrganizationId() == resource.data.organizationId);
      allow write: if request.auth != null && (isSuperAdmin() || (isManager() && getUserOrganizationId() == request.resource.data.organizationId) || (isSupervisor() && getUserOrganizationId() == request.resource.data.organizationId));
    }
    
    // Coleção de configurações (settings)
    match /settings/{teamId} {
      allow read: if request.auth != null && (isSuperAdmin() || (getUserOrganizationId() == resource.data.organizationId && getUserTeamId() == teamId));
      allow write: if request.auth != null && (isSuperAdmin() || (isManager() && getUserOrganizationId() == request.resource.data.organizationId) || (isSupervisor() && getUserOrganizationId() == request.resource.data.organizationId && getUserTeamId() == teamId));
    }
    
    // Coleção de acordos (agreements)
    match /agreements/{agreementId} {
      allow read: if request.auth != null 
        && (isSuperAdmin() || (resource == null || getUserOrganizationId() == resource.data.organizationId));
        
      allow create: if request.auth != null 
        && (isSuperAdmin() || getUserOrganizationId() == request.resource.data.organizationId);
        
      allow update, delete: if request.auth != null 
        && (
             isSuperAdmin() 
             || resource.data.operatorId == request.auth.uid 
             || ((isSupervisor() || isManager()) && getUserOrganizationId() == resource.data.organizationId)
           );
    }
    
    // Coleção de conciliações (reconciliations)
    match /reconciliations/{reconId} {
      allow read: if request.auth != null 
        && (isSuperAdmin() || (resource == null || getUserOrganizationId() == resource.data.organizationId));
      allow write: if request.auth != null 
        && (isSuperAdmin() || ((isSupervisor() || isManager()) && getUserOrganizationId() == request.resource.data.organizationId));
    }
    
    // Coleção de logs de auditoria (audit_logs)
    match /audit_logs/{logId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && (isSuperAdmin() || (isManager() && getUserOrganizationId() == resource.data.organizationId));
      allow update, delete: if false; // Logs são imutáveis e perenes
    }
  }
}
